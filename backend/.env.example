OPENAI_API_KEY=sua_chave_openai_aqui
GEMINI_API_KEY=sua_chave_gemini_aqui
DEEPSEEK_API_KEY=sua_chave_deepseek_aqui

# Provedor de IA para síntese clínica: "openai" (padrão), "deepseek" ou "gemini"
IA_MODEL_PROVIDER=openai

# Modelo específico do provedor
# OpenAI: gpt-4.1, gpt-4o, gpt-4o-mini, etc.
# DeepSeek: deepseek-chat, deepseek-reasoner
# Gemini: gemini-2.0-flash, gemini-1.5-pro, etc.
IA_MODEL=gpt-4.1

HOST=0.0.0.0
PORT=8000

# Autenticação JWT
JWT_SECRET=substitua_por_uma_chave_secreta_longa_e_aleatoria
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=480
APP_USERNAME=admin
APP_PASSWORD_HASH=substitua_pelo_hash_bcrypt

# Email para o polite pool da OpenAlex (evita rate limit de IP compartilhado)
OPENALEX_MAILTO=seu_email@exemplo.com
